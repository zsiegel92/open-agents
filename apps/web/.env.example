# Minimum runtime
POSTGRES_URL=
JWE_SECRET=

# Required to sign in and store provider tokens
# Must be a 32-byte hex string (64 characters)
ENCRYPTION_KEY=

# Vercel OAuth (required for sign-in)
# Callback URL: {YOUR_ORIGIN}/api/auth/vercel/callback
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/github/app/callback
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback
# In the GitHub App settings:
#   1. Enable "Request user authorization (OAuth) during installation"
#   2. Use the GitHub App Client ID and Client Secret below
#   3. Make the app public if you want org installs to work cleanly
#   4. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
# Use a lower value if your Vercel team cannot create 5-hour sandboxes.
# Hobby plans should use 2670000 or less; the sandbox wrapper adds a 30s buffer.
VERCEL_SANDBOX_TIMEOUT_MS=
